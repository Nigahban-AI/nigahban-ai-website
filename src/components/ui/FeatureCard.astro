---
interface Props {
  title: string;
  description: string;
  icon?: string;
  variant?: 'light' | 'dark';
}

const {
  title,
  description,
  variant = 'light',
} = Astro.props;

const isDark = variant === 'dark';
---

<div class="group">
  {/* Icon area */}
  <div class:list={[
    'w-12 h-12 rounded-xl flex items-center justify-center mb-4',
    isDark ? 'bg-amber/10' : 'bg-amber/10',
  ]}>
    <slot name="icon">
      <span class="text-amber text-xl">&#9733;</span>
    </slot>
  </div>

  <h3 class="text-xl font-heading font-semibold mb-2">
    {title}
  </h3>

  <p class:list={[isDark ? 'text-slate-light' : 'text-slate-cool']}>
    {description}
  </p>
</div>
