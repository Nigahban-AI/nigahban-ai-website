---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: 'center' | 'left';
  dark?: boolean;
}

const {
  eyebrow,
  title,
  description,
  align = 'center',
  dark = false,
} = Astro.props;

const isCenter = align === 'center';
---

<div class={isCenter ? 'text-center' : 'text-left'}>
  <p class:list={[
    'text-xs font-medium tracking-[0.2em] uppercase mb-4',
    dark ? 'text-slate-light' : 'text-slate-cool',
  ]}>
    {eyebrow}
  </p>
  <h2 class:list={[
    'text-3xl md:text-4xl lg:text-[2.75rem] font-heading font-semibold leading-tight',
    dark ? 'text-white' : 'text-navy',
  ]}>
    {title}
  </h2>
  {description && (
    <p class:list={[
      'text-lg mt-4 max-w-2xl leading-relaxed',
      dark ? 'text-slate-light' : 'text-slate-cool',
      isCenter && 'mx-auto',
    ]}>
      {description}
    </p>
  )}
</div>
