---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  align?: 'center' | 'left';
}

const {
  eyebrow,
  title,
  description,
  align = 'center',
} = Astro.props;

const isCenter = align === 'center';
---

<div class={isCenter ? 'text-center' : 'text-left'}>
  <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-3">
    {eyebrow}
  </p>
  <h2 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold mb-4">
    {title}
  </h2>
  {description && (
    <p class:list={[
      'text-lg text-slate-cool max-w-2xl',
      isCenter && 'mx-auto',
    ]}>
      {description}
    </p>
  )}
</div>
