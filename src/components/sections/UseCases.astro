---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import Section from './Section.astro';
import SectionHeader from './SectionHeader.astro';
import { FadeIn } from '@/components/react/FadeIn';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const items = ['factories', 'malls', 'warehouses', 'plazas'] as const;
---

<Section variant="light" background="none" id="use-cases">
  <SectionHeader
    eyebrow={t(locale, 'useCases.eyebrow')}
    title={t(locale, 'useCases.title')}
  />

  <FadeIn client:visible>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mt-16">
      {items.map((key) => (
        <div class="rounded-2xl border border-navy/10 bg-white p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <h3 class="text-xl font-heading font-semibold text-navy mb-2">
            {t(locale, `useCases.items.${key}.title`)}
          </h3>
          <p class="text-amber font-bold text-2xl mb-1">
            {t(locale, `useCases.items.${key}.stat`)}
          </p>
          <p class="text-sm text-slate-cool mb-3">
            {t(locale, `useCases.items.${key}.location`)}
          </p>
          <p class="text-slate-cool text-sm">
            {t(locale, `useCases.items.${key}.description`)}
          </p>
        </div>
      ))}
    </div>
  </FadeIn>
</Section>
