---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import { Image } from 'astro:assets';
import SectionHeader from './SectionHeader.astro';
import { FadeIn } from '@/components/react/FadeIn';

import factoryImg from '@/assets/photos/factory-industrial.jpg';
import mallImg from '@/assets/photos/shopping-mall.jpg';
import warehouseImg from '@/assets/photos/warehouse-interior.jpg';
import plazaImg from '@/assets/photos/commercial-plaza.jpg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const items = [
  { key: 'factories', img: factoryImg, alt: 'Industrial factory' },
  { key: 'malls', img: mallImg, alt: 'Shopping mall interior' },
  { key: 'warehouses', img: warehouseImg, alt: 'Warehouse interior' },
  { key: 'plazas', img: plazaImg, alt: 'Commercial plaza building' },
] as const;
---

<section class="bg-navy relative overflow-hidden fire-bg" id="use-cases">
  {/* CSS fire embers */}
  <div class="fire-embers">
    <span /><span /><span /><span /><span />
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative z-10">
    <SectionHeader
      eyebrow={t(locale, 'useCases.eyebrow')}
      title={t(locale, 'useCases.title')}
      dark
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-16">
      {items.map((item, i) => (
        <FadeIn client:visible delay={i * 0.1}>
          <div class="group relative overflow-hidden rounded-lg border border-white/5 hover:border-amber/20 transition-all duration-500">
            {/* Background image */}
            <div class="relative h-64 overflow-hidden">
              <Image
                src={item.img}
                alt={item.alt}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
              />
              {/* Dark overlay */}
              <div class="absolute inset-0 bg-gradient-to-t from-navy via-navy/70 to-navy/20"></div>

              {/* Camera viewfinder corners */}
              <div class="absolute top-3 left-3 w-4 h-4 border-t border-l border-amber/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute top-3 right-3 w-4 h-4 border-t border-r border-amber/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute bottom-3 left-3 w-4 h-4 border-b border-l border-amber/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="absolute bottom-3 right-3 w-4 h-4 border-b border-r border-amber/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

              {/* Content overlay */}
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <div class="flex items-baseline justify-between mb-2">
                  <h3 class="text-lg font-heading font-semibold text-white">
                    {t(locale, `useCases.items.${item.key}.title`)}
                  </h3>
                  <span class="text-amber font-heading font-semibold text-2xl">
                    {t(locale, `useCases.items.${item.key}.stat`)}
                  </span>
                </div>
                <p class="text-[11px] font-mono text-slate-cool tracking-wider uppercase mb-2">
                  {t(locale, `useCases.items.${item.key}.location`)}
                </p>
                <p class="text-slate-light text-sm leading-relaxed">
                  {t(locale, `useCases.items.${item.key}.description`)}
                </p>
              </div>
            </div>
          </div>
        </FadeIn>
      ))}
    </div>
  </div>
</section>
