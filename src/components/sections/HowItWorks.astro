---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import SectionHeader from './SectionHeader.astro';
import { FadeIn } from '@/components/react/FadeIn';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const steps = ['connect', 'nvr', 'detect', 'alert'] as const;
---

<section class="bg-navy relative overflow-hidden" id="how-it-works">
  {/* Ambient ember */}
  <div class="absolute bottom-0 left-1/3 w-[400px] h-[200px] bg-gradient-to-t from-amber/[0.04] to-transparent rounded-full blur-3xl pointer-events-none animate-ember"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative z-10">
    <SectionHeader
      eyebrow={t(locale, 'howItWorks.eyebrow')}
      title={t(locale, 'howItWorks.title')}
      dark
    />

    <div class="mt-16">
      {steps.map((step, i) => (
        <FadeIn client:visible delay={i * 0.08}>
          <div class:list={[
            'group flex items-start gap-8 lg:gap-12 py-8 lg:py-10 relative',
            i < steps.length - 1 && 'border-b border-white/5',
          ]}>
            {/* Step number with ignite glow */}
            <div class="shrink-0 w-12 relative">
              <span class="text-amber font-heading font-semibold text-lg group-hover:animate-ignite inline-block transition-all">
                {String(i + 1).padStart(2, '0')}
              </span>
              {/* Tiny flame dot */}
              <div class="absolute -top-1 -right-1 w-1.5 h-1.5 rounded-full bg-amber/50 animate-flame"></div>
            </div>

            {/* Content */}
            <div class="flex-1 max-w-lg">
              <h3 class="text-lg font-heading font-semibold text-white mb-2 group-hover:text-amber transition-colors duration-300">
                {t(locale, `howItWorks.steps.${step}.title`)}
              </h3>
              <p class="text-slate-light text-[15px] leading-relaxed">
                {t(locale, `howItWorks.steps.${step}.description`)}
              </p>
            </div>

            {/* Progress dots — right aligned */}
            <div class="hidden lg:flex items-center gap-3 shrink-0 mt-1">
              {Array.from({ length: 4 }).map((_, j) => (
                <div class:list={[
                  'w-2 h-2 rounded-full transition-all duration-300',
                  j <= i ? 'bg-amber shadow-[0_0_6px_rgba(217,119,6,0.4)]' : 'bg-white/10',
                ]} />
              ))}
            </div>

            {/* Hover ignite line at bottom */}
            <div class="absolute bottom-0 left-0 right-0 h-px">
              <div class="h-full w-0 bg-gradient-to-r from-amber to-transparent group-hover:w-1/3 transition-all duration-700 shadow-[0_0_6px_rgba(217,119,6,0.2)]"></div>
            </div>
          </div>
        </FadeIn>
      ))}
    </div>
  </div>
</section>
