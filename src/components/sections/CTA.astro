---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import { Image } from 'astro:assets';
import { FadeIn } from '@/components/react/FadeIn';
import smokeBg from '@/assets/photos/smoke-fire.jpg';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="cta" class="relative overflow-hidden fire-bg">
  {/* Background image */}
  <div class="absolute inset-0">
    <Image
      src={smokeBg}
      alt=""
      class="w-full h-full object-cover"
      widths={[800, 1600]}
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-navy/88"></div>
  </div>

  {/* CSS fire embers */}
  <div class="fire-embers">
    <span /><span /><span /><span /><span />
    <span /><span /><span /><span /><span />
  </div>
  <div class="fire-heat"></div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 text-center relative z-10">
    <FadeIn client:visible>
      <p class="text-xs font-medium tracking-[0.2em] uppercase text-amber mb-6">
        Get Started
      </p>

      <h2 class="text-3xl md:text-4xl lg:text-[2.75rem] font-heading font-semibold text-white leading-tight mb-6">
        {t(locale, 'cta.title')}
      </h2>

      <p class="text-lg text-slate-light mb-10 leading-relaxed max-w-xl mx-auto">
        {t(locale, 'cta.description')}
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="bg-amber text-navy font-semibold px-8 py-4 rounded-lg hover:bg-amber-light transition-colors text-sm tracking-wide animate-ignite"
        >
          {t(locale, 'cta.demo')}
        </a>
        <a
          href="https://wa.me/923170225941"
          target="_blank"
          rel="noopener noreferrer"
          class="border border-white/15 text-white font-medium px-8 py-4 rounded-lg hover:border-amber/30 hover:bg-white/5 transition-all text-sm tracking-wide inline-flex items-center gap-2"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          {t(locale, 'cta.whatsapp')}
        </a>
      </div>
    </FadeIn>
  </div>
</section>
