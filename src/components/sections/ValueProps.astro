---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import Section from './Section.astro';
import SectionHeader from './SectionHeader.astro';
import FeatureCard from '@/components/ui/FeatureCard.astro';
import { FadeIn } from '@/components/react/FadeIn';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const items = [
  {
    key: 'hardware',
    icon: `<svg class="w-6 h-6 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>`,
  },
  {
    key: 'speed',
    icon: `<svg class="w-6 h-6 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`,
  },
  {
    key: 'accuracy',
    icon: `<svg class="w-6 h-6 text-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
  },
];
---

<Section variant="light" background="grid" id="value-props">
  <SectionHeader
    eyebrow={t(locale, 'valueProps.eyebrow')}
    title={t(locale, 'valueProps.title')}
  />

  <FadeIn client:visible>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16">
      {items.map((item) => (
        <FeatureCard
          title={t(locale, `valueProps.items.${item.key}.title`)}
          description={t(locale, `valueProps.items.${item.key}.description`)}
        >
          <Fragment slot="icon" set:html={item.icon} />
        </FeatureCard>
      ))}
    </div>
  </FadeIn>
</Section>
