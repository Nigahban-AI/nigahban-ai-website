---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import SectionHeader from './SectionHeader.astro';
import { FadeIn } from '@/components/react/FadeIn';
import { SpotlightCard } from '@/components/react/SpotlightCard';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const items = [
  { key: 'hardware', num: '00' },
  { key: 'speed', num: '01' },
  { key: 'accuracy', num: '02' },
];
---

<section class="bg-bg" id="value-props">
  {/* Subtle ember glow at top */}
  <div class="absolute left-1/2 -translate-x-1/2 top-0 w-[500px] h-[200px] bg-gradient-to-b from-amber/[0.03] to-transparent rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative">
    <SectionHeader
      eyebrow={t(locale, 'valueProps.eyebrow')}
      title={t(locale, 'valueProps.title')}
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-border mt-16 border border-border">
      {items.map((item, i) => (
        <FadeIn client:visible delay={i * 0.1}>
          <div class="bg-surface p-8 lg:p-10 h-full group hover:bg-bg transition-colors duration-300 relative overflow-hidden">
            {/* Ember glow on hover */}
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-16 bg-gradient-to-b from-amber/0 to-transparent rounded-full blur-2xl group-hover:from-amber/[0.06] transition-all duration-700 pointer-events-none"></div>

            {/* Index number */}
            <p class="text-[11px] font-mono text-slate-cool tracking-wider mb-8">{item.num}</p>

            {/* Title */}
            <h3 class="text-xl font-heading font-semibold text-navy mb-3 group-hover:text-amber transition-colors duration-300">
              {t(locale, `valueProps.items.${item.key}.title`)}
            </h3>

            {/* Description */}
            <p class="text-slate-cool leading-relaxed text-[15px]">
              {t(locale, `valueProps.items.${item.key}.description`)}
            </p>

            {/* Ignite line on hover */}
            <div class="mt-8 h-px bg-border relative overflow-hidden">
              <div class="absolute inset-y-0 left-0 w-0 bg-amber group-hover:w-16 group-hover:shadow-[0_0_8px_rgba(217,119,6,0.3)] transition-all duration-700"></div>
            </div>
          </div>
        </FadeIn>
      ))}
    </div>
  </div>
</section>
