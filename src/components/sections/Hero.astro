---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import { Image } from 'astro:assets';
import heroImage from '@/assets/hero-fire.png';
import { FadeIn } from '@/components/react/FadeIn';
import { GlowText } from '@/components/react/GlowText';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<section id="hero" class="fire-gradient fire-bg min-h-screen flex items-center relative overflow-hidden">
  {/* CSS fire ember particles — no JS */}
  <div class="fire-embers">
    <span /><span /><span /><span /><span />
    <span /><span /><span /><span /><span />
  </div>

  {/* Heat shimmer at bottom */}
  <div class="fire-heat"></div>

  {/* Geometric accent lines */}
  <div class="absolute bottom-0 left-8 w-px h-1/2 bg-gradient-to-t from-amber/20 to-transparent pointer-events-none z-[2]"></div>
  <div class="absolute top-0 right-8 w-px h-1/3 bg-gradient-to-b from-amber/10 to-transparent pointer-events-none z-[2]"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 w-full relative z-10">
    <div class="lg:grid lg:grid-cols-12 gap-16 items-center">

      {/* Text — 7 cols */}
      <div class="lg:col-span-7">
        <FadeIn client:visible>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-amber mb-6">
            AI Fire Detection
          </p>

          <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-heading font-semibold text-white leading-[1.08] mb-8">
            {t(locale, 'hero.headline')}
            <br />
            <GlowText client:visible className="text-amber inline-block">
              {t(locale, 'hero.headlineBold')}
            </GlowText>
          </h1>

          <p class="text-lg lg:text-xl text-slate-light mb-10 max-w-xl leading-relaxed">
            {t(locale, 'hero.subheadline')}
          </p>

          <div class="flex flex-wrap gap-4 mb-14">
            <a
              href="/contact"
              class="bg-amber text-navy font-semibold px-7 py-3.5 rounded-lg hover:bg-amber-light transition-colors text-sm tracking-wide fire-glow-subtle"
            >
              {t(locale, 'hero.cta')}
            </a>
            <a
              href="#how-it-works"
              class="border border-white/15 text-white px-7 py-3.5 rounded-lg hover:border-amber/30 hover:bg-white/5 transition-all text-sm tracking-wide"
            >
              {t(locale, 'hero.ctaSecondary')}
            </a>
          </div>

          {/* Metrics strip */}
          <div class="flex gap-10 flex-wrap">
            <div>
              <p class="text-2xl font-heading font-semibold text-white">&lt; 3s</p>
              <p class="text-xs text-slate-cool mt-1 tracking-wide uppercase">Detection</p>
            </div>
            <div class="w-px bg-white/10"></div>
            <div>
              <p class="text-2xl font-heading font-semibold text-white">99.52%</p>
              <p class="text-xs text-slate-cool mt-1 tracking-wide uppercase">Accuracy</p>
            </div>
            <div class="w-px bg-white/10"></div>
            <div>
              <p class="text-2xl font-heading font-semibold text-white">0</p>
              <p class="text-xs text-slate-cool mt-1 tracking-wide uppercase">Hardware needed</p>
            </div>
          </div>
        </FadeIn>
      </div>

      {/* Image — 5 cols with camera viewfinder */}
      <div class="lg:col-span-5 mt-12 lg:mt-0">
        <FadeIn client:visible direction="right" delay={0.2}>
          <div class="relative camera-viewfinder p-2">
            {/* Scan line */}
            <div class="absolute left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber/50 to-transparent z-20 pointer-events-none" style="animation: scan 4s ease-in-out infinite;"></div>

            <Image
              src={heroImage}
              alt="AI fire detection in action"
              class="rounded-sm w-full h-auto relative z-10"
              widths={[400, 800]}
              sizes="(max-width: 1024px) 100vw, 42vw"
            />

            {/* Top-right corner bracket */}
            <div class="absolute top-0 right-0 w-5 h-5 border-t-[1.5px] border-r-[1.5px] border-amber/50 pointer-events-none"></div>
            {/* Bottom-left corner bracket */}
            <div class="absolute bottom-0 left-0 w-5 h-5 border-b-[1.5px] border-l-[1.5px] border-amber/50 pointer-events-none"></div>

            {/* Overlays */}
            <div class="absolute top-4 left-4 z-20 bg-navy/80 backdrop-blur-sm border border-white/10 text-white text-[10px] font-mono px-2.5 py-1 rounded-sm tracking-wider">
              LIVE &middot; CAM-01 &middot; 1080p
            </div>
            <div class="absolute bottom-4 right-4 z-20 bg-danger/90 text-white text-[10px] font-semibold px-2.5 py-1 rounded-sm flex items-center gap-1.5 tracking-wider">
              <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span>
              FIRE DETECTED
            </div>
          </div>
        </FadeIn>
      </div>
    </div>
  </div>
</section>
