---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Section from '@/components/sections/Section.astro';
import SectionHeader from '@/components/sections/SectionHeader.astro';
import { getCollection } from 'astro:content';

const locale = 'ur' as const;

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryColors: Record<string, string> = {
  product: 'bg-amber/10 text-amber-dark',
  industry: 'bg-blue-500/10 text-blue-700',
  safety: 'bg-red-500/10 text-red-700',
  engineering: 'bg-emerald-500/10 text-emerald-700',
  company: 'bg-purple-500/10 text-purple-700',
};
---

<Layout title="نگہبان AI — بلاگ">
  <Header locale={locale} />
  <main>
    <Section variant="dark" background="dots">
      <SectionHeader
        eyebrow="بلاگ"
        title="فائر سیفٹی بصیرت اور پروڈکٹ اپڈیٹس"
        description="پاکستان میں فائر سیفٹی، AI ڈیٹیکشن ٹیکنالوجی، اور بلڈنگ کمپلائنس پر ماہرانہ تجزیہ۔"
      />
    </Section>

    <Section variant="light">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a
              href={`/ur/blog/${post.id}`}
              class="group rounded-2xl border border-slate-cool/10 overflow-hidden hover:-translate-y-1 transition flex flex-col bg-white"
            >
              {post.data.heroImage && (
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-6 flex flex-col flex-1">
                <span
                  class:list={[
                    'text-xs font-semibold px-2 py-1 rounded w-fit mb-3',
                    categoryColors[post.data.category] || 'bg-amber/10 text-amber-dark',
                  ]}
                >
                  {post.data.category}
                </span>
                <h3 class="text-xl font-heading font-semibold mb-2 group-hover:text-amber transition-colors">
                  {post.data.title}
                </h3>
                <p class="text-slate-cool text-sm mb-4 flex-1">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between text-xs text-slate-cool">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('ur-PK', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  <span>{post.data.author}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-2xl font-heading font-semibold text-navy mb-2">جلد آ رہا ہے</p>
          <p class="text-slate-cool">
            ہم فائر سیفٹی اور AI ڈیٹیکشن کے بارے میں بصیرت افروز مضامین پر کام کر رہے ہیں۔ جلد دوبارہ چیک کریں!
          </p>
        </div>
      )}
    </Section>
  </main>
  <Footer locale={locale} />
</Layout>
