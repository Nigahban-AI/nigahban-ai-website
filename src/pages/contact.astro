---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Section from '@/components/sections/Section.astro';
import SectionHeader from '@/components/sections/SectionHeader.astro';
import { getLocale } from '@/lib/i18n';

const locale = getLocale(Astro.url);
---

<Layout title="Contact Us | Nigahban AI" description="Get in touch with Nigahban AI. Schedule a free demo, request a pilot program, or ask about AI fire detection for your building.">
  <Header locale={locale} />
  <main>
    <Section variant="dark" background="dots">
      <SectionHeader
        eyebrow="Contact"
        title="Get in Touch"
        description="Ready to protect your building? Reach out for a free consultation or demo."
      />
    </Section>

    <Section variant="light">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-heading font-bold text-navy mb-6">Send Us a Message</h2>
          <form action="/api/contact" method="POST" class="space-y-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-navy mb-1">Name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-xl border border-slate-cool/20 px-4 py-3 text-navy placeholder:text-slate-cool/50 focus:border-amber focus:ring-2 focus:ring-amber/20 outline-none transition"
                placeholder="Your full name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold text-navy mb-1">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-xl border border-slate-cool/20 px-4 py-3 text-navy placeholder:text-slate-cool/50 focus:border-amber focus:ring-2 focus:ring-amber/20 outline-none transition"
                placeholder="you@company.com"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-semibold text-navy mb-1">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-xl border border-slate-cool/20 px-4 py-3 text-navy placeholder:text-slate-cool/50 focus:border-amber focus:ring-2 focus:ring-amber/20 outline-none transition"
                placeholder="+92-XXX-XXXXXXX"
              />
            </div>

            <div>
              <label for="company" class="block text-sm font-semibold text-navy mb-1">Company / Building Name</label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full rounded-xl border border-slate-cool/20 px-4 py-3 text-navy placeholder:text-slate-cool/50 focus:border-amber focus:ring-2 focus:ring-amber/20 outline-none transition"
                placeholder="Your company or building name"
              />
            </div>

            <div>
              <label for="cameras" class="block text-sm font-semibold text-navy mb-1">Number of Cameras</label>
              <select
                id="cameras"
                name="cameras"
                class="w-full rounded-xl border border-slate-cool/20 px-4 py-3 text-navy focus:border-amber focus:ring-2 focus:ring-amber/20 outline-none transition bg-white"
              >
                <option value="">Select range</option>
                <option value="1-4">1 - 4 cameras</option>
                <option value="5-16">5 - 16 cameras</option>
                <option value="17-50">17 - 50 cameras</option>
                <option value="50+">50+ cameras</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold text-navy mb-1">Message *</label>
              <textarea
                id="message"
                name="message"
                required
                rows="4"
                class="w-full rounded-xl border border-slate-cool/20 px-4 py-3 text-navy placeholder:text-slate-cool/50 focus:border-amber focus:ring-2 focus:ring-amber/20 outline-none transition resize-y"
                placeholder="Tell us about your building and fire safety needs..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="bg-amber text-navy font-semibold rounded-xl px-6 py-3 hover:bg-amber/90 transition-colors w-full sm:w-auto"
            >
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-6">
          <h2 class="text-2xl font-heading font-bold text-navy mb-6">Direct Contact</h2>

          <!-- WhatsApp Card -->
          <a
            href="https://wa.me/92XXXXXXXXXX"
            target="_blank"
            rel="noopener noreferrer"
            class="block rounded-2xl bg-emerald-600 text-white p-6 hover:bg-emerald-700 transition-colors"
          >
            <div class="flex items-center gap-4">
              <svg class="h-8 w-8 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <div>
                <p class="font-heading font-bold text-lg">WhatsApp Us</p>
                <p class="text-emerald-100 text-sm">Quick response — chat with our team directly</p>
              </div>
            </div>
          </a>

          <!-- Email Card -->
          <a
            href="mailto:info@nigahban.ai"
            class="block rounded-2xl border border-slate-cool/10 bg-white p-6 hover:-translate-y-0.5 transition"
          >
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-xl bg-amber/10 flex items-center justify-center flex-shrink-0">
                <svg class="h-6 w-6 text-amber-dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="20" height="16" x="2" y="4" rx="2" />
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
              </div>
              <div>
                <p class="font-heading font-semibold text-navy">Email</p>
                <p class="text-slate-cool text-sm">info@nigahban.ai</p>
              </div>
            </div>
          </a>

          <!-- Phone Card -->
          <a
            href="tel:+92XXXXXXXXXX"
            class="block rounded-2xl border border-slate-cool/10 bg-white p-6 hover:-translate-y-0.5 transition"
          >
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-xl bg-amber/10 flex items-center justify-center flex-shrink-0">
                <svg class="h-6 w-6 text-amber-dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </div>
              <div>
                <p class="font-heading font-semibold text-navy">Phone</p>
                <p class="text-slate-cool text-sm">+92-XXX-XXXXXXX</p>
              </div>
            </div>
          </a>

          <!-- Address Card -->
          <div class="rounded-2xl border border-slate-cool/10 bg-white p-6">
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-xl bg-amber/10 flex items-center justify-center flex-shrink-0">
                <svg class="h-6 w-6 text-amber-dark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </div>
              <div>
                <p class="font-heading font-semibold text-navy">Address</p>
                <p class="text-slate-cool text-sm">NIC Karachi, Pakistan</p>
              </div>
            </div>
          </div>

          <!-- Free Pilot Card -->
          <div class="rounded-2xl bg-navy text-white p-6">
            <div class="flex items-start gap-4">
              <div class="h-12 w-12 rounded-xl bg-amber/20 flex items-center justify-center flex-shrink-0">
                <svg class="h-6 w-6 text-amber" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                </svg>
              </div>
              <div>
                <p class="font-heading font-bold text-lg mb-1">Free Pilot Program</p>
                <p class="text-slate-300 text-sm">
                  Qualifying buildings get a free 30-day pilot. Book a demo to learn more about eligibility and see Nigahban AI in action on your own cameras.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Section>
  </main>
  <Footer locale={locale} />
</Layout>
