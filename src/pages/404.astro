---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
---

<Layout title="404 — Page Not Found | Nigahban AI">
  <Header />
  <main class="min-h-[70vh] flex items-center justify-center bg-navy text-white">
    <div class="text-center px-4">
      <p class="text-amber text-8xl font-heading font-bold mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-heading font-bold mb-4">Page Not Found</h1>
      <p class="text-slate-light text-lg mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block bg-amber text-navy font-semibold rounded-xl px-6 py-3 hover:bg-amber-dark transition"
      >
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
</Layout>
