---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Section from '@/components/sections/Section.astro';
import SectionHeader from '@/components/sections/SectionHeader.astro';
import GlassCard from '@/components/ui/GlassCard.astro';
import { FadeIn } from '@/components/react/FadeIn';
import { getLocale } from '@/lib/i18n';

const locale = getLocale(Astro.url);

const values = [
  {
    title: 'Safety First',
    description: 'Every decision we make is measured against one question: does this make buildings safer? We never cut corners on detection accuracy or alert speed.',
  },
  {
    title: 'Accessible Technology',
    description: 'Advanced AI should not be a luxury. We built Nigahban to work with the cameras buildings already have — no expensive upgrades, no complex installations.',
  },
  {
    title: 'Built in Pakistan',
    description: 'We understand Pakistani infrastructure, building codes, and fire risks because we live here. Our AI is trained on local environments and conditions.',
  },
  {
    title: 'Transparent AI',
    description: 'Every detection comes with a captured frame and confidence score. You can see exactly what triggered the alert — no black box, no mystery.',
  },
];
---

<Layout title="About — Nigahban AI Fire Detection">
  <Header locale={locale} />
  <main>
    {/* Hero */}
    <Section variant="dark" background="dots" id="about-hero">
      <div class="min-h-[60vh] flex items-center -my-20 lg:-my-28">
        <div class="max-w-3xl mx-auto text-center">
          <FadeIn client:visible>
            <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-4">About Us</p>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white leading-tight mb-6">
              Protecting Pakistan Through
              <span class="text-amber"> Intelligent Fire Detection</span>
            </h1>
            <p class="text-xl text-slate-light max-w-2xl mx-auto">
              We are on a mission to ensure no building with working CCTV cameras ever loses lives to undetected fire.
            </p>
          </FadeIn>
        </div>
      </div>
    </Section>

    {/* Mission */}
    <Section variant="light" id="mission">
      <div class="max-w-4xl mx-auto text-center">
        <FadeIn client:visible>
          <p class="text-3xl md:text-4xl font-heading font-bold leading-relaxed">
            Making fire safety accessible to
            <span class="text-amber"> every building in Pakistan</span>
            through AI.
          </p>
        </FadeIn>
      </div>
    </Section>

    {/* Story */}
    <Section variant="charcoal" id="story">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <FadeIn client:visible direction="left">
          <div>
            <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-4">Our Story</p>
            <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">Why We Built Nigahban</h2>
            <div class="space-y-4 text-slate-light text-lg">
              <p>
                In January 2026, the Gul Plaza tragedy in Karachi claimed 73 lives. The building had CCTV cameras installed. They were recording. But nobody was watching.
              </p>
              <p>
                By the time someone noticed the smoke on a monitor, the fire had already engulfed three floors. Families lost everything. The footage existed — the warning did not.
              </p>
              <p>
                We built Nigahban because we believe existing technology should be enough. If a camera can see fire, AI should raise the alarm — instantly, automatically, without waiting for a human to notice.
              </p>
              <p>
                <strong class="text-white">Nigahban means "guardian" in Urdu.</strong> That is what we are building: an AI guardian that watches when humans cannot.
              </p>
            </div>
          </div>
        </FadeIn>
        <FadeIn client:visible direction="right" delay={0.2}>
          <div class="space-y-8">
            <div class="glass rounded-2xl p-8 text-center">
              <p class="text-5xl font-heading font-bold text-amber mb-2">73</p>
              <p class="text-slate-light">Lives lost in the Gul Plaza fire</p>
            </div>
            <div class="glass rounded-2xl p-8 text-center">
              <p class="text-5xl font-heading font-bold text-amber mb-2">80%</p>
              <p class="text-slate-light">of commercial buildings in Karachi have CCTV</p>
            </div>
            <div class="glass rounded-2xl p-8 text-center">
              <p class="text-5xl font-heading font-bold text-amber mb-2">&lt; 3s</p>
              <p class="text-slate-light">Nigahban detection-to-alert time</p>
            </div>
          </div>
        </FadeIn>
      </div>
    </Section>

    {/* NIC Karachi */}
    <Section variant="light" id="nic-karachi">
      <div class="max-w-3xl mx-auto text-center">
        <FadeIn client:visible>
          <p class="text-amber text-sm font-semibold tracking-widest uppercase mb-4">Incubation</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">
            Incubated at NIC Karachi, Cohort 15
          </h2>
          <p class="text-lg text-slate-cool max-w-2xl mx-auto mb-4">
            Nigahban AI is proudly incubated at the National Incubation Center (NIC) Karachi — Pakistan's premier technology incubator, powered by Jazz and Teamup.
          </p>
          <p class="text-slate-cool max-w-2xl mx-auto">
            NIC Karachi has supported over 500 startups since its founding. Being part of Cohort 15 gives us access to mentorship, industry connections, and the resources to scale our fire safety technology across Pakistan.
          </p>
        </FadeIn>
      </div>
    </Section>

    {/* Values */}
    <Section variant="dark" background="dots" id="values">
      <FadeIn client:visible>
        <SectionHeader
          eyebrow="Values"
          title="What Drives Us"
          description="The principles behind everything we build at Nigahban."
        />
      </FadeIn>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-16">
        {values.map((value, i) => (
          <FadeIn client:visible delay={i * 0.1}>
            <GlassCard className="h-full">
              <h3 class="text-xl font-heading font-semibold text-amber mb-3">{value.title}</h3>
              <p class="text-slate-light">{value.description}</p>
            </GlassCard>
          </FadeIn>
        ))}
      </div>
    </Section>

    {/* CTA */}
    <Section variant="dark" background="none" className="bg-gradient-to-r from-navy to-charcoal">
      <div class="max-w-3xl mx-auto text-center">
        <FadeIn client:visible>
          <h2 class="text-3xl md:text-4xl font-heading font-bold mb-6">
            Join the Mission
          </h2>
          <p class="text-lg text-slate-light mb-10">
            Whether you want to protect your building or partner with us — we would love to hear from you.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href="/contact"
              class="bg-amber text-navy font-semibold px-8 py-4 rounded-xl hover:brightness-110 transition-all text-lg"
            >
              Get in Touch
            </a>
          </div>
        </FadeIn>
      </div>
    </Section>
  </main>
  <Footer locale={locale} />
</Layout>
